{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": [
      "./.opencode/skills"
    ]
  },
  "mcp": {
    "zread": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/zread/sse",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {file:.secrets/zread_api_key}"
      }
    },
    "web-search-prime": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {file:.secrets/zread_api_key}"
      }
    },
    "web-reader": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {file:.secrets/zread_api_key}"
      }
    }
  },
  "permission": {
    "web-search-prime_*": "allow",
    "web-reader_*": "allow",
    "zread_*": "allow"
  }
}
