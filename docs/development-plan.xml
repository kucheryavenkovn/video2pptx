  <DataFlow>
    <DF-001 NAME="DetectPipeline" TRIGGER="CLI detect command (all-in-one)">
      <step-1>Load config (M-CONFIG)</step-1>
      <step-2>Open video, iterate sampled frames, detect changes (M-SLIDE-DETECTOR via M-VIDEO-DECODE, M-ROI, M-FRAME-FEATURES)</step-2>
      <step-3>Build segments + dedupe (M-SEGMENTER, M-DEDUPE)</step-3>
      <step-4>Parse subtitles and align cues (M-SUBTITLES) — optional</step-4>
      <step-5>Save screenshots + slides.json</step-5>
      <step-6>Run notes if subtitles provided (M-NOTES) — optional</step-6>
      <step-7>Export MD/PPTX — optional, M-MD-EXPORT, M-PPTX-EXPORT</step-7>
      <evidence>slides.json, slides/*.png, optional deck.md, deck.pptx</evidence>
    </DF-001>

    <DF-005 NAME="DetectSlidesPipeline" TRIGGER="CLI detect-slides command">
      <step-1>Load config (M-CONFIG)</step-1>
      <step-2>Open video, iterate sampled frames, detect changes (M-SLIDE-DETECTOR)</step-2>
      <step-3>Build segments + dedupe (M-SEGMENTER, M-DEDUPE)</step-3>
      <step-4>Save screenshots + slides.json without transcript fields</step-4>
      <evidence>slides.json with intervals and images, no transcript. Run in ~same time as detect pass.</evidence>
    </DF-005>

    <DF-004 NAME="NotesPipeline" TRIGGER="CLI notes command">
      <step-1>Load existing slides.json (M-MODELS)</step-1>
      <step-2>Parse subtitles, align cues to existing segments (M-SUBTITLES) — optional, skip if no subtitles</step-2>
      <step-3>For each slide: read screenshot → vision analyze via LLM → slide context (M-SLIDE-ANALYZER) — optional, skip in basic mode</step-3>
      <step-4>Build speaker notes from cues + slide context (M-NOTES-PROCESSOR basic/llm)</step-4>
      <step-5>Write enriched slides.json with cleaned notes</step-5>
      <evidence>slides.json transcript fields updated. No video re-decoding needed. Fast execution.</evidence>
    </DF-004>

    <DF-006 NAME="RoiToolFlow" TRIGGER="CLI roi-tool command">
      <step-1>Open video, extract one representative frame</step-1>
      <step-2>Display frame in OpenCV window with mouse drag rectangle</step-2>
      <step-3>On Enter/Space: output "x1,y1,x2,y2" to stdout</step-3>
      <step-4>On Esc: exit with no output</step-4>
      <evidence>Coordinates printed to stdout, pipeable into --ignore-roi</evidence>
    </DF-006>

    <DF-003 NAME="LlmProcessPipeline" TRIGGER="CLI llm-process command">
      <step-1>Load slides.json (M-CLI)</step-1>
      <step-2>Read LlmConfig (M-CONFIG)</step-2>
      <step-3>Initialize LlmClient (M-LLM-CLIENT)</step-3>
      <step-4>For each slide: vision analyze → structured description (M-SLIDE-ANALYZER)</step-4>
      <step-5>Save descriptions + transcript correction (M-LLM-ORCHESTRATOR)</step-5>
      <evidence>enriched slides.json with llm_description fields</evidence>
    </DF-003>

    <DF-002 NAME="ExportMDPipeline" TRIGGER="CLI export-md command">
      <step-1>Load slides.json (M-CLI)</step-1>
      <step-2>Generate Marp Markdown (M-MD-EXPORT)</step-2>
      <step-3>Write deck.md</step-3>
      <evidence>deck.md renders in Marp viewer</evidence>
    </DF-002>
  </DataFlow>

