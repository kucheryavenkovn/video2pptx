      <path>src/video_slide_md/subtitles.py</path>
      <depends>M-MODELS</depends>
      <verification-ref>V-M-SUBTITLES</verification-ref>
    </M-SUBTITLES>

    <M-MD-EXPORT NAME="MarkdownExport" TYPE="CORE_LOGIC" STATUS="implemented">
