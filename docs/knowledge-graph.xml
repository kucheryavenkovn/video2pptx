      <path>src/video_slide_md/dedupe.py</path>
      <depends>M-MODELS, M-FRAME-FEATURES</depends>
      <verification-ref>V-M-DEDUPE</verification-ref>
    </M-DEDUPE>

    <M-SUBTITLES NAME="Subtitles" TYPE="CORE_LOGIC" STATUS="implemented">
