    <M-LLM-ORCHESTRATOR NAME="LlmOrchestrator" TYPE="CORE_LOGIC" STATUS="implemented">
      <purpose>Orchestrate LLM pipeline: load model → analyze slides → rephrase → unload → save</purpose>
      <path>src/video_slide_md/llm_orchestrator.py</path>
      <depends>M-LLM-CLIENT, M-SLIDE-ANALYZER, M-NOTES-PROCESSOR</depends>
      <verification-ref>V-M-LLM-ORCHESTRATOR</verification-ref>
    </M-LLM-ORCHESTRATOR>

    <M-PIPELINE NAME="PipelineOrchestrator" TYPE="CORE_LOGIC" STATUS="implemented">
      <purpose>Wire all modules in CLI detect (all-in-one mode)</purpose>
      <path>src/video_slide_md/cli.py</path>
