<?xml version="1.0" encoding="UTF-8"?>
<KnowledgeGraph>
  <Project NAME="video-slide-md" VERSION="0.2.0">
    <keywords>video, slides, markdown, presentation, open-cv, computer-vision, slide-detection, subtitle-alignment</keywords>
    <annotation>Automatically extract slide intervals from educational videos, link to SRT/VTT subtitles, enhance with LLM vision analysis, and export presentations.</annotation>

    <M-MODELS NAME="Models" TYPE="UTILITY" STATUS="implemented">
      <purpose>Pydantic data models for slides document</purpose>
      <path>src/video_slide_md/models.py</path>
      <depends>none</depends>
      <verification-ref>V-M-MODELS</verification-ref>
      <annotations>
        <type-SlidesDocument PURPOSE="Root document containing all slide segments" />
        <type-SlideSegment PURPOSE="Single slide interval with transcript and metadata" />
        <type-VideoInfo PURPOSE="Source video metadata" />
        <type-SubtitleCue PURPOSE="Single subtitle entry with time and text" />
      </annotations>
    </M-MODELS>

    <M-CLI NAME="CLI" TYPE="ENTRY_POINT" STATUS="implemented">
      <purpose>Typer CLI entry point for detect, detect-slides, notes, roi-tool, export-md, export-pptx, llm-process, debug commands</purpose>
      <path>src/video_slide_md/cli.py</path>
      <depends>M-CONFIG, M-DETECT-SLIDES, M-NOTES, M-ROI-TOOL</depends>
      <verification-ref>V-M-CLI</verification-ref>
      <annotations>
        <fn-detect PURPOSE="All-in-one: video + optional subtitles → slides.json + images + optional exports" />
        <fn-detect_slides PURPOSE="Standalone: video only → slides.json + screenshots, no subtitles" />
        <fn-notes PURPOSE="Post-process: slides.json + subtitles + slide images → enriched notes" />
        <fn-roi_tool PURPOSE="GUI: video frame → mouse drag rect → ignore-roi coordinates" />
        <fn-export-md PURPOSE="Export slides.json to Marp Markdown presentation" />
        <fn-export-pptx PURPOSE="Export slides.json to PPTX presentation" />
        <fn-llm_process PURPOSE="Enrich slides.json with LLM vision analysis and corrected transcript" />
      </annotations>
    </M-CLI>

    <M-CONFIG NAME="Config" TYPE="UTILITY" STATUS="implemented">
      <purpose>Configuration loading — YAML file + CLI arg merge</purpose>
      <path>src/video_slide_md/config.py</path>
      <depends>M-MODELS</depends>
      <verification-ref>V-M-CONFIG</verification-ref>
    </M-CONFIG>

    <M-VIDEO-DECODE NAME="VideoDecode" TYPE="CORE_LOGIC" STATUS="implemented">
      <purpose>Video frame decoding and sampling at given fps with multi-backend support</purpose>
      <path>src/video_slide_md/video_decode.py</path>
      <depends>M-BACKENDS</depends>
      <verification-ref>V-M-VIDEO-DECODE</verification-ref>
    </M-VIDEO-DECODE>

    <M-BACKENDS NAME="Backends" TYPE="INTEGRATION" STATUS="implemented">
      <purpose>Video decoder backends: OpenCV, PyAV</purpose>
      <path>src/video_slide_md/backends/</path>
      <depends>none</depends>
      <verification-ref>V-M-BACKENDS</verification-ref>
      <submodules>
        <M-BACKEND-OPENCV NAME="OpenCVBackend" STATUS="implemented" />
        <M-BACKEND-PYAV NAME="PyAVBackend" STATUS="implemented" />
      </submodules>
    </M-BACKENDS>

    <M-ROI NAME="ROI" TYPE="CORE_LOGIC" STATUS="implemented">
      <purpose>Slide ROI management — crop and mask ignore regions</purpose>
      <path>src/video_slide_md/roi.py</path>
      <depends>M-MODELS</depends>
      <verification-ref>V-M-ROI</verification-ref>
    </M-ROI>

    <M-FRAME-FEATURES NAME="FrameFeatures" TYPE="CORE_LOGIC" STATUS="implemented">
      <purpose>Frame feature extraction: pHash, dHash, histogram, grayscale, pixel MAE, visual distance</purpose>
      <path>src/video_slide_md/frame_features.py</path>
      <depends>M-ROI</depends>
      <verification-ref>V-M-FRAME-FEATURES</verification-ref>
    </M-FRAME-FEATURES>

    <M-SLIDE-DETECTOR NAME="SlideDetector" TYPE="CORE_LOGIC" STATUS="implemented">
      <purpose>Slide change detection via frame comparison with threshold and debounce</purpose>
      <path>src/video_slide_md/slide_detector.py</path>
      <depends>M-FRAME-FEATURES, M-ROI</depends>
      <verification-ref>V-M-SLIDE-DETECTOR</verification-ref>
    </M-SLIDE-DETECTOR>

    <M-SEGMENTER NAME="Segmenter" TYPE="CORE_LOGIC" STATUS="implemented">
      <purpose>Convert change events to slide intervals with representative timestamps</purpose>
      <path>src/video_slide_md/segmenter.py</path>
      <depends>M-MODELS</depends>
      <verification-ref>V-M-SEGMENTER</verification-ref>
    </M-SEGMENTER>

    <M-DEDUPE NAME="Dedupe" TYPE="CORE_LOGIC" STATUS="implemented">
