<?xml version="1.0" encoding="UTF-8"?>
<VerificationPlan VERSION="0.1.0">
  <GlobalPolicy>
    <log-format>[ModuleName][function_name][BLOCK_NAME] message | key=value</log-format>
    <deterministic-first>true</deterministic-first>
    <module-level-focus>Fast deterministic unit checks for each module.</module-level-focus>
    <wave-level-focus>Integration checks across pipeline stages with synthetic videos.</wave-level-focus>
    <phase-level-focus>Synthetic video end-to-end tests with metric assertions.</phase-level-focus>
    <mvp-metrics>
      <missed_slide_rate val="<=5%" source="synthetic dataset" />
      <false_split_rate val="<=10%" source="synthetic dataset" />
      <timestamp_error_seconds val="<=1.5" source="at sample_fps=2" />
    </mvp-metrics>
    <redaction>Never log secrets, credentials, or raw high-risk payloads.</redaction>
  </GlobalPolicy>

  <CriticalFlows>
    <VF-001 NAME="DetectHappyPath" USE_CASES="UC-001" DATA_FLOW="DF-001" PRIORITY="high">
      <scenario>User provides valid MP4 + SRT — pipeline produces slides.json + images with correct intervals.</scenario>
      <expected-outcome>slides.json validates, slide images saved, transcript aligned.</expected-outcome>
      <required-signals>
        <log-marker>[SlideDetector][detect_changes][BLOCK_COMPARE_FRAMES]</log-marker>
        <log-marker>[Segmenter][build_segments][BLOCK_BUILD_INTERVALS]</log-marker>
        <log-marker>[Subtitles][align_cues][BLOCK_OVERLAP_CALC]</log-marker>
      </required-signals>
    </VF-001>

    <VF-002 NAME="ExportMDPath" USE_CASES="UC-002" DATA_FLOW="DF-002" PRIORITY="high">
      <scenario>Valid slides.json → deck.md with correct Marp formatting.</scenario>
      <expected-outcome>deck.md renders in Marp viewer with images and transcript.</expected-outcome>
      <required-signals>
        <log-marker>[MarkdownExport][export_deck][BLOCK_GENERATE_MD]</log-marker>
      </required-signals>
    </VF-002>

    <VF-004 NAME="ExportPptxPath" USE_CASES="UC-002" DATA_FLOW="DF-002" PRIORITY="high">
      <scenario>Valid slides.json + images → deck.pptx with full-slide pictures and speaker notes.</scenario>
      <expected-outcome>deck.pptx has correct slide count, notes contain transcript, images embedded.</expected-outcome>
      <required-signals>
        <log-marker>[PptxExport][export_to_pptx][BLOCK_PPTX_BUILD]</log-marker>
      </required-signals>
    </VF-004>

    <VF-003 NAME="GPUAutoFallback" USE_CASES="UC-001" DATA_FLOW="DF-001" PRIORITY="medium">
      <scenario>System without CUDA — auto backend falls back to OpenCV with warning.</scenario>
      <expected-outcome>Pipeline completes on CPU with WARNING log line.</expected-outcome>
      <required-signals>
        <log-marker>[VideoDecode][select_backend][BLOCK_FALLBACK_CPU] (level=WARNING)</log-marker>
      </required-signals>
    </VF-003>
  </CriticalFlows>

  <ModuleVerification>
    <V-M-MODELS MODULE="M-MODELS" PRIORITY="high" STATUS="passed">
      <test-files><file>tests/test_models.py</file></test-files>
      <module-checks>
        <check-1>pytest tests/test_models.py -v</check-1>
      </module-checks>
      <scenarios>
        <scenario-1 kind="success">SlidesDocument serialization round-trip works.</scenario-1>
        <scenario-2 kind="success">SlideSegment defaults are correct.</scenario-2>
        <scenario-3 kind="failure">Invalid duration is rejected by ge=0 constraint.</scenario-3>
      </scenarios>
    </V-M-MODELS>

