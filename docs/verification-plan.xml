<?xml version="1.0" encoding="UTF-8"?>
<VerificationPlan VERSION="0.2.0">
  <GlobalPolicy>
    <log-format>[ModuleName][function_name][BLOCK_NAME] message | key=value</log-format>
    <deterministic-first>true</deterministic-first>
    <module-level-focus>Fast deterministic unit checks for each module.</module-level-focus>
    <wave-level-focus>Integration checks across pipeline stages with synthetic videos.</wave-level-focus>
    <phase-level-focus>Synthetic video end-to-end tests with metric assertions.</phase-level-focus>
    <mvp-metrics>
      <missed_slide_rate val="<=5%" source="synthetic dataset" />
      <false_split_rate val="<=10%" source="synthetic dataset" />
      <timestamp_error_seconds val="<=1.5" source="at sample_fps=2" />
    </mvp-metrics>
    <redaction>Never log secrets, credentials, or raw high-risk payloads.</redaction>
  </GlobalPolicy>

  <CriticalFlows>
    <VF-001 NAME="DetectHappyPath" USE_CASES="UC-001" DATA_FLOW="DF-001" PRIORITY="high">
      <scenario>User provides valid MP4 + SRT — pipeline produces slides.json + images with correct intervals.</scenario>
      <expected-outcome>slides.json validates, slide images saved, transcript aligned.</expected-outcome>
    </VF-001>

    <VF-002 NAME="ExportMDPath" USE_CASES="UC-002" DATA_FLOW="DF-002" PRIORITY="high">
      <scenario>Valid slides.json → deck.md with correct Marp formatting.</scenario>
      <expected-outcome>deck.md renders in Marp viewer.</expected-outcome>
    </VF-002>

    <VF-003 NAME="GPUAutoFallback" USE_CASES="UC-001" DATA_FLOW="DF-001" PRIORITY="medium">
      <scenario>System without CUDA — auto backend falls back to OpenCV with warning.</scenario>
      <expected-outcome>Pipeline completes on CPU with WARNING log line.</expected-outcome>
    </VF-003>

    <VF-004 NAME="ExportPptxPath" USE_CASES="UC-002" DATA_FLOW="DF-002" PRIORITY="high">
      <scenario>Valid slides.json + images → deck.pptx with full-slide pictures and speaker notes.</scenario>
      <expected-outcome>deck.pptx has correct slide count, notes contain cleaned transcript, images embedded.</expected-outcome>
    </VF-004>

    <VF-005 NAME="NotesProcessingPath" USE_CASES="UC-001" DATA_FLOW="DF-002" PRIORITY="medium">
      <scenario>Segment with SRT cues → process_notes(basic) → clean speaker notes text.</scenario>
      <expected-outcome>Raw subtitle fragments joined, punctuated, deduplicated into flowing text.</expected-outcome>
    </VF-005>

    <VF-006 NAME="DetectSlidesNoSubtitles" USE_CASES="UC-005" DATA_FLOW="DF-005" PRIORITY="high">
      <scenario>User runs detect-slides with only a video — no subtitles.</scenario>
      <expected-outcome>slides.json produced with intervals and representative timestamps. Transcript fields may be empty. No error.</expected-outcome>
    </VF-006>

    <VF-007 NAME="NotesPostProcess" USE_CASES="UC-006" DATA_FLOW="DF-004" PRIORITY="high">
      <scenario>User runs detect first, then later runs notes with different subtitles/notes-mode. No video re-decode.</scenario>
      <expected-outcome>Notes command loads existing slides.json, aligns new subtitles, generates notes, saves. Runs in seconds, not minutes.</expected-outcome>
    </VF-007>

    <VF-008 NAME="RoiToolVisualSelect" USE_CASES="UC-007" DATA_FLOW="DF-006" PRIORITY="medium">
      <scenario>User runs roi-tool with a video, drags a rectangle, presses Enter.</scenario>
      <expected-outcome>Coordinates printed to stdout in format x1,y1,x2,y2. Window closes cleanly.</expected-outcome>
    </VF-008>
  </CriticalFlows>

