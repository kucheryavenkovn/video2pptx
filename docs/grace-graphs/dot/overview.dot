digraph G {
  rankdir=TB;
  graph [fontname="Helvetica", fontsize=12, label="GRACE Overview", labelloc=t, overlap=false, splines=true, newrank=true];
  node [shape=box, style="rounded,filled", fillcolor="#E8F1FF", fontname="Helvetica", fontsize=10];
  edge [fontname="Helvetica", fontsize=9, color="#555555"];

  subgraph cluster_hub {
    label="hub";
    style=rounded;
    bgcolor="#FFFDE7";
    CriticalFlows [label="CriticalFlows\\n18"];
    CrossLinks [label="CrossLinks\\n187"];
    DataFlows [label="DataFlows\\n26"];
    DependsEdges [label="depends_on\\n258"];
    Modules [label="Modules\\n125"];
    Phases [label="Phases\\n20"];
    UseCases [label="UseCases\\n17"];
    Verifications [label="Verifications\\n66"];
  }


  Modules -> DependsEdges [label="has"];
  Modules -> Verifications [label="verified_by"];
  Modules -> CrossLinks [label="linked"];
  UseCases -> DataFlows [label="related"];
  UseCases -> CriticalFlows [label="covered_by"];
  Phases -> Modules [label="implements"];
  CriticalFlows -> Verifications [label="checks"];
}
